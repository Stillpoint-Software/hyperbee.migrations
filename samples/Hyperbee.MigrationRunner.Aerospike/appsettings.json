{
  "Aerospike": {
    "ConnectionString": "localhost:3000"
  },
  "Migrations": {
    "Namespace": "test",
    "MigrationSet": "SchemaMigrations",
    "Lock": {
      "Enabled": false,
      "Name": "migration_lock",
      "MaxLifetime": 3600
    },
    "FromPaths": [
      "..\\..\\..\\..\\..\\samples\\Hyperbee.Migrations.Aerospike.Samples\\bin\\Debug\\net10.0\\Hyperbee.Migrations.Aerospike.Samples.dll"
    ],
    "FromAssemblies": [
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Aerospike": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  }
}
